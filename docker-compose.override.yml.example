version: '3.8'

# Docker Compose Override for Local Development
# This file is automatically loaded if present (takes precedence over docker-compose.yml)
# Uncomment services you want to override for local development

services:
  backend:
    # Mount source code for live reload
    volumes:
      - ./Backend:/app/Backend
    environment:
      - PYTHONUNBUFFERED=1
      - DEBUG=1

  frontend:
    # Mount source code for live reload
    volumes:
      - ./Frontend:/app/Frontend
    environment:
      - DEBUG=1

  postgres:
    # Allow connections from outside container during development
    ports:
      - "5432:5432"
